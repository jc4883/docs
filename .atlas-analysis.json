{
  "projectType": "cli-tool",
  "projectName": "Muscat",
  "projectDescription": "A TypeScript CLI tool that fetches your Twitter/X timeline and AI-focused search results, then generates a structured AI news digest using Claude Code slash commands.",
  "theme": "luma",
  "primaryColor": "#1D9BF0",
  "lightColor": "#E8F5FF",
  "darkColor": "#0A1929",
